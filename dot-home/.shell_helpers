#!/bin/bash
# vim: set ft=sh ts=4 sts=4 sw=4 et:

# .shell_helpers
# Contains utility functions and aliases, shell-agnostic.

search() {
  [ $# -eq 0 ] && { echo "usage: search <pattern> [files...]"; return 1; }

  if command -v rg >/dev/null 2>&1; then
    rg --smart-case --hidden --follow --no-heading --line-number \
      --glob '!.{git,vscode-server,cache,cargo,svn}' \
      --glob '!{node_modules,venv,.venv,env,.env}' \
      "$@"
  else
    grep -r --color=auto \
      --exclude-dir={.git,.vscode-server,.cache,.cargo,.svn,node_modules,venv,.venv,env,.env} \
      "$@" .
  fi
}

# Get public IP
alias myip='curl -fsS ifconfig.me; echo'

mkcd() { mkdir -p -- "$1" && cd -- "$1"; }

# Find files quickly
ff() {
  [ $# -lt 1 ] && { echo "usage: ff <pattern> [path]" >&2; return 1; }
  local path="${2:-.}"

  command -v fd >/dev/null 2>&1 && { fd -i "$1" "$path"; return; }
  command -v fdfind >/dev/null 2>&1 && { fdfind -i "$1" "$path"; return; }
  find "$path" -type f -iname "*$1*" 2>/dev/null
}

# Get C and C++ includes
show_includes() {
  for cmd in gcc g++; do
    echo -e "\n [ $cmd includes ]"

    local lang="c"
    [[ "$cmd" == "g++" ]] && lang="c++"
    # gcc -E -Wp,-v -xc    is the standard way
    $cmd -E -v -x "$lang" /dev/null 2>&1 \
      | sed -n '/#include <...>/,/End of search list./p' \
      | grep '^ ' \
      | sed 's/^ //'
  done
}

sysinfo() {
  printf "host:   %s\n" "$(hostname)"
  printf "kernel: %s\n" "$(uname -sr)"
  printf "uptime: %s\n" "$(uptime -p 2>/dev/null || uptime)"
  printf "cpu:    %s\n" "$(grep -m1 'model name' /proc/cpuinfo | cut -d ':' -f2- | xargs)"
  echo
  free -h
}

extract() {
  [ -z "$1" ] && {
    echo "usage: extract <archive>"
    return 1
  }

  [ ! -f "$1" ] && {
    echo "error: '$1' not found"
    return 1
  }

  case "$1" in
    *.tar.bz2|*.tbz2) tar xjf "$1" ;;
    *.tar.gz|*.tgz)   tar xzf "$1" ;;
    *.tar.xz)         tar xJf "$1" ;;
    *.tar)            tar xf "$1" ;;
    *.bz2)            bunzip2 "$1" ;;
    *.gz)             gunzip "$1" ;;
    *.xz)             unxz "$1" ;;
    *.zip)            unzip "$1" ;;
    *.rar)            unrar x "$1" ;;
    *.7z)             7z x "$1" ;;
    *.Z)              uncompress "$1" ;;
    *) echo "error: cannot extract '$1'" ;;
  esac
}

# Generate a random password
genpass() {
  local len=${1:-16}
  [[ "$len" =~ ^[0-9]+$ ]] && [ "$len" -gt 0 ] || {
    echo "usage: genpass [length, default 16]" >&2
    return 1
  }

  LC_ALL=C tr -dc 'A-Za-z0-9!@#$%^&*()_+' < /dev/urandom | head -c "$len"
  echo
}

verify_checksum() {
  [ $# -ne 2 ] && { echo "usage: verify_checksum <file> <expected_sha256>"; return 1; }

  local file="$1"
  local expected="${2#sha256:}"
  local actual

  [ ! -f "$file" ] && { echo "error: file '$file' not found"; return 1; }

  if command -v sha256sum >/dev/null 2>&1; then
    read -r actual _ < <(sha256sum "$file")
  elif command -v shasum >/dev/null 2>&1; then
    read -r actual _ < <(shasum -a 256 "$file")
  else
    echo "error: no sha256 tool available"
    return 1
  fi

  if [ "$actual" = "$expected" ]; then
    printf "[ok]   %s\n" "$file"
  else
    printf "[fail] %s\n" "$file"
    printf "  expected: %s\n" "$expected"
    printf "  actual:   %s\n" "$actual"
    return 1
  fi
}

# Removes Zone.Identifier files that appear from file transfers
# Usage: dezones [optional: directory]
dezones() {
    local dir="${1:-.}"
    local count=$(find "$dir" -type f -name "*:Zone.Identifier" -delete -print 2> /dev/null | wc -l)
    if [ "$count" -gt 0 ]; then
        echo "Removed $count Zone.Identifier file(s) under $dir"
    else
        echo "No Zone.Identifier files found under $dir"
    fi
}

# Kills the process occupying a certain port
killport() {
  [ -z "$1" ] && { echo "usage: killport <port>"; return 1; }
  local pids
  pids=$(ss -ltnp 2>/dev/null | awk -v p=":$1" '$4 ~ p { gsub(/.*pid=|,.*/, "", $NF); print $NF }')
  [ -z "$pids" ] && { echo "no process on port $1"; return 1; }
  echo "killing pids: $pids"
  for pid in $pids; do kill "$pid" 2>/dev/null || sudo kill -9 "$pid"; done
}

# Search running processes
psgrep() {
  [ $# -lt 1 ] && { echo "usage: psgrep <pattern>"; return 1; }
  ps aux | (command -v rg >/dev/null 2>&1 \
    && rg -i -e "^USER" -e "$1" \
    || grep -i -E "^USER|$1")
}

if command -v nvim >/dev/null 2>&1; then
  alias nvim_goto_config='cd ~/.config/nvim'
  alias nvim_dump_swap='rm -rf ~/.local/state/nvim/swap'
  alias nvim_server='nvim --headless --listen localhost:6666'

  nvim_reset() {
    rm -rf ~/.local/share/nvim \
           ~/.local/state/nvim \
           ~/.cache/nvim
    rm -f  ~/.config/nvim/lazy-lock.json
    echo "neovim reset complete."
  }

  nvim_size() {
    local config=~/.config/nvim
    local data=~/.local/share/nvim
    local cache=~/.cache/nvim
    local lazy="$data/lazy"
    local mason="$data/mason"
    local ts="$lazy/nvim-treesitter/parser"

    size_kb() {
      [ -d "$1" ] && du -sk "$1" 2>/dev/null | awk '{print $1}' || echo 0
    }

    config_kb=$(size_kb "$config")
    lazy_kb=$(size_kb "$lazy")
    mason_kb=$(size_kb "$mason")
    ts_kb=$(size_kb "$ts")
    cache_kb=$(size_kb "$cache")

    total_kb=$((config_kb + lazy_kb + mason_kb + ts_kb + cache_kb))

    lazy_no_git_kb=0
    if [ -d "$lazy" ]; then
      lazy_no_git_kb=$(find "$lazy" -type d -name .git -prune -o -type f -print 2>/dev/null | du -sk 2>/dev/null | awk '{print $1+0}')
    fi

    count_dirs() {
      [ -d "$1" ] && find "$1" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l || echo 0
    }

    plugins=$(count_dirs "$lazy")
    lsps=$(count_dirs "$mason/packages")
    tss=$(count_dirs "$ts")

    fmt() {
      if command -v numfmt >/dev/null 2>&1; then
        numfmt --to=iec --suffix=B --format="%.1f" "$(($1 * 1024))"
      else
        printf "%s KB" "$1"
      fi
    }

    printf '\n%s\n' 'neovim footprint'
    printf '%s\n\n' '-----------------'

    printf "%-18s %12s\n" "config"              "$(fmt "$config_kb")"
    printf "%-18s %12s\n" "plugins ($plugins)"  "$(fmt "$lazy_kb")"
    printf "%-18s %12s\n" "  without .git"      "$(fmt "$lazy_no_git_kb")"
    printf "%-18s %12s\n" "lsps ($lsps)"        "$(fmt "$mason_kb")"
    printf "%-18s %12s\n" "treesitters ($tss)"  "$(fmt "$ts_kb")"
    printf "%-18s %12s\n" "cache"               "$(fmt "$cache_kb")"

    printf "\n%-18s %12s\n" "total" "$(fmt "$total_kb")"
  }
fi
